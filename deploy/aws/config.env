#!/bin/bash
# AWS Deployment Configuration - Auto-saved Sat, Mar 14, 2026  9:42:27 AM

# User Configuration
export DOMAIN_NAME="retainingwallplan.com"
export SSH_KEY_NAME="retaining_wall"
export ADMIN_EMAIL="computer1@smithson1.com"
export HOSTED_ZONE_ID=""

# AWS Settings
export AWS_REGION="us-west-2"
export AWS_PROFILE="default"

# VPC Configuration
export VPC_CIDR="10.0.0.0/16"
export PUBLIC_SUBNET_CIDR="10.0.1.0/24"
export VPC_NAME="retaining-wall-vpc"

# EC2 Configuration
export INSTANCE_TYPE="t3.small"
export AMI_ID=""
export INSTANCE_NAME="retaining-wall-server"
export EBS_SIZE="30"

# Application Settings
export APP_USER="ubuntu"
export DEPLOY_USER="github-deploy"
export APP_DIR="/opt/rwcpp"
export WEB_DIR="/var/www/retainingwall"
export LOG_DIR="/var/log/rwcpp"

# Resource IDs (populated by scripts)
export VPC_ID="vpc-01b2c04da91dacf88"
export SUBNET_ID="subnet-07ce4574941d9a8eb"
export IGW_ID="igw-0c35c82865760c148"
export RTB_ID="rtb-03d324cf61c9ee05a"
export SG_ID="sg-0d67d3b6899952255"
export INSTANCE_ID="i-073cf4949e3a248a0"
export EIP_ALLOC_ID="eipalloc-0466308e7719ea5d8"
export ELASTIC_IP="100.20.175.49"

# =============================================================================
# Helper Functions
# =============================================================================

# Save current config to file - ONLY updates resource IDs, preserves template structure
save_config() {
    local config_file="${1:-$(dirname "$0")/config.env}"
    
    # Create a temporary file with updated resource IDs
    local temp_file=$(mktemp)
    
    # Copy the file but replace resource ID lines
    while IFS= read -r line; do
        case "$line" in
            "export VPC_ID="*) echo "export VPC_ID=\"${VPC_ID}\"" ;;
            "export SUBNET_ID="*) echo "export SUBNET_ID=\"${SUBNET_ID}\"" ;;
            "export IGW_ID="*) echo "export IGW_ID=\"${IGW_ID}\"" ;;
            "export RTB_ID="*) echo "export RTB_ID=\"${RTB_ID}\"" ;;
            "export SG_ID="*) echo "export SG_ID=\"${SG_ID}\"" ;;
            "export INSTANCE_ID="*) echo "export INSTANCE_ID=\"${INSTANCE_ID}\"" ;;
            "export EIP_ALLOC_ID="*) echo "export EIP_ALLOC_ID=\"${EIP_ALLOC_ID}\"" ;;
            "export ELASTIC_IP="*) echo "export ELASTIC_IP=\"${ELASTIC_IP}\"" ;;
            *) echo "$line" ;;
        esac
    done < "${config_file}" > "${temp_file}"
    
    # Replace original file
    mv "${temp_file}" "${config_file}"
    echo "Configuration saved to ${config_file}"
}

# Validate required settings
validate_config() {
    local errors=0

    if [[ "${DOMAIN_NAME}" == "your-domain.com" ]]; then
        echo "ERROR: DOMAIN_NAME not configured"
        errors=$((errors + 1))
    fi

    if [[ "${SSH_KEY_NAME}" == "retaining-wall-key" ]]; then
        echo "WARNING: Using default SSH_KEY_NAME. Make sure this key pair exists in AWS."
    fi

    if [[ "${ADMIN_EMAIL}" == "admin@your-domain.com" ]]; then
        echo "ERROR: ADMIN_EMAIL not configured"
        errors=$((errors + 1))
    fi

    # Check AWS CLI is installed and configured
    if ! command -v aws &> /dev/null; then
        echo "ERROR: AWS CLI not installed"
        errors=$((errors + 1))
    elif ! aws sts get-caller-identity &> /dev/null; then
        echo "ERROR: AWS CLI not configured or credentials invalid"
        errors=$((errors + 1))
    fi

    return ${errors}
}

echo "Retaining Wall AWS Deployment Configuration loaded"
echo "Domain: ${DOMAIN_NAME}"
echo "Region: ${AWS_REGION}"
